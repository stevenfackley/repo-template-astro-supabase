# Required
DATABASE_URL=postgres://user:pass@host:5432/postgres

# S3-compatible object storage (Cloudflare R2 in prod, MinIO locally).
# For R2: S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=          # e.g. https://cdn.example.com (optional)

# Optional
NODE_ENV=production
PORT=4321
HOST=0.0.0.0
