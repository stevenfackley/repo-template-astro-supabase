{
  "permissions": {
    "allow": [
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(docker compose:*)",
      "Bash(docker build:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(npm run:*)",
      "Bash(npm ci)",
      "Bash(npm install:*)",
      "Bash(npx astro:*)",
      "Bash(npx drizzle-kit:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright:*)",
      "Bash(npx tsx:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl logs:*)",
      "Bash(helm template:*)",
      "Bash(helm diff:*)",
      "Bash(psql:*)",
      "Bash(pg_isready:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(aws iam:*)",
      "Bash(npx drizzle-kit drop:*)"
    ]
  },
  "env": { "POWERSHELL_TELEMETRY_OPTOUT": "1" },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "pwsh -NoProfile -File .claude/hooks/format-node.ps1" }
        ]
      }
    ]
  }
}
